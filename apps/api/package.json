{
  "name": "@koinonia/api",
  "version": "0.1.0",
  "description": "Koinonia API - Fastify backend",
  "main": "./dist/server.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "pnpm db:test:migrate && vitest",
    "test:watch": "vitest --watch",
    "db:test:migrate": "tsx src/scripts/test-migrate.ts",
    "db:migrate": "drizzle-kit migrate",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/scripts/seed.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@koinonia/shared": "workspace:*",
    "fastify": "^4.27.0",
    "@fastify/cors": "^9.0.0",
    "@fastify/jwt": "^7.2.4",
    "@fastify/multipart": "^8.0.0",
    "@fastify/static": "^7.0.0",
    "drizzle-orm": "^0.31.0",
    "postgres": "^3.4.4",
    "zod": "^3.22.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "drizzle-kit": "^0.22.0",
    "eslint": "^8.57.0",
    "tsx": "^4.7.0",
    "typescript": "^5.0.0",
    "vitest": "^1.3.0"
  }
}
